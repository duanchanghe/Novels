# ===========================================
# AI 有声书工坊 - 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# ===========================================

# ---------- 应用基础配置 ----------
APP_NAME=ai-audiobook-workshop
APP_ENV=development          # development / staging / production
APP_DEBUG=true               # 是否开启调试模式
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-secret-key-change-in-production

# ---------- 数据库配置 ----------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=audiobook_db
DB_USER=audiobook_user
DB_PASSWORD=your-db-password
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ---------- Redis 配置 ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ---------- Celery 配置 ----------
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ---------- MinIO 对象存储配置 ----------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false           # 是否使用 HTTPS
MINIO_BUCKET_EPUB=books-epub
MINIO_BUCKET_AUDIO=books-audio

# ---------- DeepSeek API 配置 ----------
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=4096
DEEPSEEK_TEMPERATURE=0.7

# ---------- MiniMax TTS API 配置 ----------
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_API_HOST=https://api.minimax.chat
MINIMAX_GROUP_ID=your-group-id

# ---------- 文件夹监听配置 ----------
WATCH_DIR=/books/incoming
WATCH_INTERVAL=60            # Celery Beat 扫描间隔（秒）
WATCH_ENABLED=true           # 是否启用文件夹监听

# ---------- 音频处理配置 ----------
AUDIO_SAMPLE_RATE=44100
AUDIO_BITRATE=192
AUDIO_CROSSFADE_MS=20        # 交叉淡入淡出时长（毫秒）

# ---------- 日志配置 ----------
LOG_LEVEL=INFO               # DEBUG / INFO / WARNING / ERROR
LOG_FILE=logs/app.log

# ---------- CORS 配置 ----------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------- 发布渠道配置 ----------
# 喜马拉雅开放平台
XIMALAYA_APP_ID=your-ximalaya-app-id
XIMALAYA_APP_SECRET=your-ximalaya-app-secret

# 蜻蜓 FM
QINGTING_APP_ID=your-qingting-app-id
QINGTING_APP_SECRET=your-qingting-app-secret
